generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./database.db"
}

model Team {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  captainPhone String
  players      Player[]
}

model Player {
  id     Int    @id @default(autoincrement())
  name   String
  age    Int
  teamId Int
  team   Team   @relation(fields: [teamId], references: [id])
}